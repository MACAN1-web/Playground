# Обязательно поменять перед production
AUTH_SECRET=change-this-long-random-secret

# PostgreSQL внутри docker-compose
POSTGRES_DB=college_rating
POSTGRES_USER=college_app
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_PORT=5432

# Порты на сервере
BACKEND_PORT=3001
CLIENT_PORT=8080
ADMIN_PORT=8081

# Адреса, с которых frontend/admin имеют право обращаться к backend
APP_ORIGIN=http://localhost:8080,http://localhost:8081

# API URL, который будет встроен в client/admin во время docker build
VITE_API_URL=http://localhost:3001
