{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "apps/backend/src",
    "outDir": "dist-server"
  },
  "include": ["apps/backend/src/**/*.ts"]
}
