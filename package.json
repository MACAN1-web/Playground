{
  "name": "college-rating",
  "private": true,
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "tsx apps/backend/src/index.ts",
    "dev:client": "vite --config vite.client.config.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:client": "vite build --config vite.client.config.ts",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build": "npm run build:backend && npm run build:client && npm run build:admin",
    "start:backend": "node dist-server/index.js",
    "test": "node --test scripts/api.test.mjs",
    "db:migrate": "tsx apps/backend/src/migrate.ts",
    "admin:create": "tsx apps/backend/src/seed-admin.ts",
    "db:transfer-sqlite": "tsx scripts/transfer-sqlite-to-postgres.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^8.0.16",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "better-sqlite3": "^11.10.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3"
  }
}
